{
  "name": "n8n-nodes-viral-app",
  "version": "0.2.11",
  "description": "n8n node for ViralApp API - Video analytics for TikTok, Instagram, and YouTube",
  "keywords": [
    "n8n-community-node-package",
    "viralapp",
    "analytics",
    "tiktok",
    "instagram",
    "youtube"
  ],
  "license": "MIT",
  "homepage": "https://viral.app",
  "author": {
    "name": "ViralApp",
    "email": "support@viral.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmd-labs/n8n-nodes-viral-app.git"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@10.23.0",
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "dev:hot": "concurrently \"tsc --watch\" \"N8N_DEV_RELOAD=true n8n start\"",
    "format": "prettier nodes credentials --write",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "lintfix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ViralAppApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ViralApp/ViralApp.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@n8n/node-cli": "0.30.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.48.0",
    "@typescript-eslint/utils": "^8.48.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.4",
    "gulp": "^5.0.1",
    "prettier": "^3.7.0",
    "release-it": "20.0.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
